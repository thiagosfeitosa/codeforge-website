node_modules/
*/node_modules/

# ──────────────────────────────────────────────
#  Build outputs
# ──────────────────────────────────────────────
dist/
build/
.next/
out/
*/dist/
*/build/

# TypeScript incremental build info
*.tsbuildinfo
*/*.tsbuildinfo

# ──────────────────────────────────────────────
#  Environment variables  (never commit secrets)
# ──────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local
*/.env
*/.env.local
*/.env.development
*/.env.production
*/.env.test

# ──────────────────────────────────────────────
#  Logs
# ──────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ──────────────────────────────────────────────
#  Test & coverage artefacts
# ──────────────────────────────────────────────
coverage/
*/coverage/
.nyc_output/

# ──────────────────────────────────────────────
#  Editor & OS
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────
#  Misc tooling caches
# ──────────────────────────────────────────────
.cache/
.temp/
.tmp/
.parcel-cache/
.eslintcache
.stylelintcache

# ──────────────────────────────────────────────
#  Docker
